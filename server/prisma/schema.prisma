generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// ENUMS
// ==================================================

enum SystemRole {
  SUPER_ADMIN
  ORG_ADMIN
  TEAM_LEAD
  DEVELOPER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

// ==================================================
// USER MODEL
// ==================================================

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  fullName      String
  avatarUrl     String?

  role          SystemRole     @default(DEVELOPER)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Organization Relation
  orgId         String?
  organization  Organization?  @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // Relations
  teamMembers   TeamMember[]
  assignedTasks Task[]         @relation("TaskAssignee")
  createdTasks  Task[]         @relation("TaskCreator")
  messages      ChatMessage[]
  notifications Notification[]

  // Activity Logs
  activityLogs  ActivityLog[]

  @@index([email])
}

// ==================================================
// ORGANIZATION MODEL
// ==================================================

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  users         User[]
  teams         Team[]
  projects      Project[]
  activityLogs  ActivityLog[]

  @@index([slug])
}

// ==================================================
// TEAM MODEL
// ==================================================

model Team {
  id           String       @id @default(uuid())
  name         String

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Organization Relation
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Relations
  members      TeamMember[]
  projects     Project[]
  chatMessages ChatMessage[]
}

// ==================================================
// TEAM MEMBER MODEL
// ==================================================

model TeamMember {
  id        String   @id @default(uuid())

  joinedAt  DateTime @default(now())

  // Team Relation
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // User Relation
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ==================================================
// PROJECT MODEL
// ==================================================

model Project {
  id           String       @id @default(uuid())
  name         String

  description  String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Organization Relation
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Team Relation
  teamId       String?
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Relations
  tasks         Task[]
  activityLogs  ActivityLog[]
}

// ==================================================
// TASK MODEL
// ==================================================

model Task {
  id          String       @id @default(uuid())

  title       String
  description String?

  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)

  dueDate     DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Project Relation
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Assignee Relation
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Creator Relation
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ==================================================
// CHAT MESSAGE MODEL
// ==================================================

model ChatMessage {
  id        String   @id @default(uuid())

  message   String

  createdAt DateTime @default(now())

  // Team Relation
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // User Relation
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ==================================================
// NOTIFICATION MODEL
// ==================================================

model Notification {
  id        String   @id @default(uuid())

  title     String
  body      String

  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  // User Relation
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================================================
// ACTIVITY LOG MODEL
// ==================================================

model ActivityLog {
  id           String       @id @default(uuid())

  action       String

  createdAt    DateTime     @default(now())

  // Organization Relation
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // User Relation
  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional Project Relation
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
}